# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=sofaart.ru,www.sofaart.ru,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://sofaart.ru,https://www.sofaart.ru,http://127.0.0.1,http://localhost
SITE_NAME=SofaArt
SITE_URL=https://sofaart.ru

# HTTPS/security flags.
# Для HTTP-only запуска оставьте False.
# После настройки TLS на VPS рекомендуется включить True.
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False

# PostgreSQL
POSTGRES_DB=myshop
POSTGRES_USER=myshop
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://127.0.0.1:6379/1
DJANGO_USE_REDIS_CACHE=True

# Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/2
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/3
CELERY_TASK_DEFAULT_QUEUE=default

# Gunicorn / container startup
PORT=8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
DJANGO_RUN_MIGRATIONS=1
DJANGO_COLLECTSTATIC=1

# Email.
# Для локальной разработки можно использовать console backend.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=change-me-email-password
DEFAULT_FROM_EMAIL=SofaArt <info@sofaart.ru>
SERVER_EMAIL=noreply@example.com
